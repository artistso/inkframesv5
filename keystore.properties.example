# Copy this file to `keystore.properties` (git-ignored) and enter the real
# long-lived release-key values. Never commit this file or the .jks keystore.
#
# Create the key once:
#   keytool -genkeypair -v -keystore inkframe-release.jks -alias inkframe \
#     -keyalg RSA -keysize 4096 -validity 10000
#
# CI uses equivalent environment variables:
#   INKFRAME_KEYSTORE
#   INKFRAME_KEYSTORE_PASSWORD
#   INKFRAME_KEY_ALIAS
#   INKFRAME_KEY_PASSWORD

storeFile=/absolute/path/to/inkframe-release.jks
storePassword=CHANGE_ME
keyAlias=inkframe
keyPassword=CHANGE_ME
