# Copy this file to `keystore.properties` (which is git-ignored) and fill in your
# real values to build a SIGNED release locally. Never commit the real file or the .jks.
#
# Create a keystore once with:
#   keytool -genkey -v -keystore inkframe-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias inkframe
#
storeFile=inkframe-release.jks
storePassword=CHANGE_ME
keyAlias=inkframe
keyPassword=CHANGE_ME
