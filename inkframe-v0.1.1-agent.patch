+name: Agent Build
+
+# Agent Mode / CLI-triggerable build
+# Trigger with:
+#   gh workflow run agent-build.yml -f task=apk
+#   gh run watch
+#   gh run download <run-id> -n inkframe-agent-apk
+#
+# This is the pipeline Agent Mode uses to build InkFrame headlessly.
+
+on:
+  workflow_dispatch:
+    inputs:
+      task:
+        description: 'Task to run'
+        required: true
+        default: 'apk'
+        type: choice
+        options:
+          - apk
+          - web
+          - test
+          - all
+      version_bump:
+        description: 'Bump version before build? (patch/minor/major/none)'
+        required: false
+        default: 'none'
+        type: choice
+        options:
+          - none
+          - patch
+          - minor
+          - major
+
+permissions:
+  contents: read
+
+jobs:
+  agent:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Set up Node 20
+        if: contains(inputs.task, 'web') || inputs.task == 'all'
+        uses: actions/setup-node@v4
+        with:
+          node-version: '20'
+
+      - name: Bump version (if requested)
+        if: inputs.version_bump != 'none'
+        run: |
+          node tools/bump-version.mjs ${{ inputs.version_bump }}
+          cat web/metadata.json
+
+      - name: Web build
+        if: contains(inputs.task, 'web') || inputs.task == 'all'
+        run: |
+          cd web
+          npm ci
+          npm run build
+
+      - name: Set up JDK 17
+        if: contains(inputs.task, 'apk') || inputs.task == 'all' || contains(inputs.task, 'test')
+        uses: actions/setup-java@v4
+        with:
+          distribution: temurin
+          java-version: '17'
+
+      - name: Set up Android SDK
+        if: contains(inputs.task, 'apk') || inputs.task == 'all' || contains(inputs.task, 'test')
+        uses: android-actions/setup-android@v3
+
+      - name: Install Android platform
+        if: contains(inputs.task, 'apk') || inputs.task == 'all' || contains(inputs.task, 'test')
+        run: sdkmanager "platforms;android-35" "build-tools;35.0.0"
+
+      - name: Gradle cache
+        if: contains(inputs.task, 'apk') || inputs.task == 'all' || contains(inputs.task, 'test')
+        uses: gradle/actions/setup-gradle@v4
+
+      - name: Test
+        if: contains(inputs.task, 'test') || inputs.task == 'all'
+        run: |
+          chmod +x ./gradlew
+          ./gradlew test --stacktrace
+
+      - name: Build APK
+        if: contains(inputs.task, 'apk') || inputs.task == 'all'
+        run: |
+          chmod +x ./gradlew
+          ./gradlew :app:assembleDebug --stacktrace
+
+      - name: Upload APK
+        if: contains(inputs.task, 'apk') || inputs.task == 'all'
+        uses: actions/upload-artifact@v4
+        with:
+          name: inkframe-agent-apk
+          path: app/build/outputs/apk/debug/*.apk
+          retention-days: 30
+
+      - name: Upload web dist
+        if: contains(inputs.task, 'web') || inputs.task == 'all'
+        uses: actions/upload-artifact@v4
+        with:
+          name: inkframe-web-dist
+          path: web/dist
+          if-no-files-found: ignore
+          retention-days: 14
