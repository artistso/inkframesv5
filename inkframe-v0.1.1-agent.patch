+#!/usr/bin/env node
+/**
+ * InkFrame Studio - CLI pipeline helper
+ * 
+ * Wraps:
+ *  - web dev/build
+ *  - Android gradle build
+ *  - .inkframe archive export to GIF/MP4 (headless, via puppeteer)
+ *  - version bump / release checks (delegates to existing tools/)
+ * 
+ * MIT License
+ */
+
+import { spawn } from 'node:child_process';
+import { fileURLToPath } from 'node:url';
+import path from 'node:path';
+import fs from 'node:fs/promises';
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+const root = path.resolve(__dirname, '..');
+
+function run(cmd, args, opts={}) {
+  return new Promise((res, rej) => {
+    const p = spawn(cmd, args, { stdio: 'inherit', cwd: root, ...opts });
+    p.on('close', c => c===0 ? res(0) : rej(new Error(`${cmd} exited ${c}`)));
+  });
+}
+
+async function exportGif(inArchive, outGif, {fps=12, width=null} = {}) {
+  // Headless export using Puppeteer + the in-browser GifEncoder
+  // This re-uses web/index.html + web/gif-encoder.js, so output is bit-identical
+  // to the in-app export.
+  let puppeteer;
+  try {
+    puppeteer = await import('puppeteer');
+  } catch {
+    console.error('export-gif needs puppeteer. Install once with:\n  cd web && npm install puppeteer --save-dev');
+    process.exit(1);
+  }
+  const browser = await puppeteer.default.launch({ headless: true, args: ['--no-sandbox'] });
+  const page = await browser.newPage();
+  const indexUrl = 'file://' + path.resolve(root, 'web/index.html');
+  await page.goto(indexUrl, { waitUntil: 'domcontentloaded' });
+  // Inject the .inkframe archive
+  const archiveBuf = await fs.readFile(inArchive);
+  const archiveB64 = archiveBuf.toString('base64');
+
+  const result = await page.evaluate(async ({archiveB64, fps, width}) => {
+    // The app stores autosave in IndexedDB - we bypass that and inject directly
+    // by parsing the archive JSON format (v3 archive: {v, projects:[...]} )
+    const bin = Uint8Array.from(atob(archiveB64), c => c.charCodeAt(0));
+    const text = new TextDecoder().decode(bin);
+    const payload = JSON.parse(text);
+    const P = (payload.projects && payload.projects[0]) || payload.project || payload;
+    // Flatten frames via the app's own composite path
+    // Simplified: use the built-in export (window.INKFRAME export not exposed,
+    // so we reconstruct)
+    // For this CLI we use the GifEncoder directly, same as the app.
+    const frames = P.frames || [];
+    if(!frames.length) throw new Error('No frames in archive');
+
+    // Build canvases from data URLs
+    async function loadLayerCanvas(layer, w, h) {
+      const c = document.createElement('canvas'); c.width=w; c.height=h;
+      const g = c.getContext('2d');
+      if(layer.png) {
+        const img = new Image();
+        await new Promise((res,rej)=>{ img.onload=res; img.onerror=rej; img.src=layer.png; });
+        g.drawImage(img,0,0,w,h);
+      }
+      return c;
+    }
+    const W = P.w || 1024, H = P.h || 768;
+    const outW = width ? width : W;
+    const outH = Math.round(H * outW / W);
+
+    const enc = new GifEncoder(outW, outH, { loop: true });
+    for(let fi=0; fi<frames.length; fi++){
+      const fr = frames[fi];
+      const comp = document.createElement('canvas'); comp.width=outW; comp.height=outH;
+      const gc = comp.getContext('2d');
+      gc.fillStyle = P.paper || '#fff0f3';
+      gc.fillRect(0,0,outW,outH);
+      const layers = fr.layers || [{png: fr.png}];
+      for(const L of layers){
+        if(L.visible === false) continue;
+        const lc = await loadLayerCanvas(L, outW, outH);
+        gc.globalAlpha = typeof L.opacity === 'number' ? L.opacity : 1;
+        gc.globalCompositeOperation = L.blend || 'source-over';
+        gc.drawImage(lc,0,0);
+      }
+      gc.globalAlpha = 1; gc.globalCompositeOperation = 'source-over';
+      const imgd = gc.getImageData(0,0,outW,outH);
+      // Convert RGBA -> ARGB Int32 for GifEncoder
+      const argb = new Int32Array(outW*outH);
+      const d = imgd.data;
+      for(let i=0,j=0;i<argb.length;i++,j+=4){
+        argb[i] = (d[j+3]<<24) | (d[j]<<16) | (d[j+1]<<8) | d[j+2];
+      }
+      const hold = (P.holds && P.holds[fi]) || 1;
+      const delayCs = Math.max(2, Math.round(100 / fps)) * hold;
+      enc.addFrame(argb, delayCs);
+    }
+    const bytes = enc.finish();
+    // return as base64
+    let binary = '';
+    const chunk = 0x8000;
+    for(let i=0;i<bytes.length;i+=chunk) binary += String.fromCharCode(...bytes.subarray(i,i+chunk));
+    return btoa(binary);
+  }, {archiveB64, fps, width});
+
+  await browser.close();
+  const outBuf = Buffer.from(result, 'base64');
+  await fs.writeFile(outGif, outBuf);
+  console.log(`GIF exported: ${outGif}  ${(outBuf.length/1024).toFixed(1)} KB`);
+}
+
+async function main(){
+  const [cmd, ...args] = process.argv.slice(2);
+  if(!cmd || cmd === 'help'){
+    console.log(`
+InkFrame CLI (node)
+
+  export-gif <in.inkframe> <out.gif> [--fps 12] [--width 1024]
+  export-mp4 <in.inkframe> <out.mp4>  [--fps 12]   (requires ffmpeg)
+
+For dev/build/apk/test/bump use the bash wrapper:
+  ./inkframe-cli dev
+  ./inkframe-cli build-apk
+`);
+    process.exit(0);
+  }
+  if(cmd === 'export-gif'){
+    const [inFile, outFile, ...rest] = args;
+    if(!inFile || !outFile){ console.error('Usage: export-gif <in.inkframe> <out.gif> [--fps N] [--width W]'); process.exit(1); }
+    const opts = {};
+    for(let i=0;i<rest.length;i+=2){ if(rest[i]==='--fps') opts.fps = Number(rest[i+1]); if(rest[i]==='--width') opts.width = Number(rest[i+1]); }
+    await exportGif(inFile, outFile, opts);
+    return;
+  }
+  if(cmd === 'export-mp4' || cmd === 'export-video'){
+    console.error('MP4 export via CLI: first export GIF, then: ffmpeg -i out.gif -movflags +faststart -pix_fmt yuv420p out.mp4\nOr use the in-app Video export (H.264/VP9 via MediaRecorder).');
+    process.exit(1);
+  }
+  console.error('Unknown command:', cmd);
+  process.exit(1);
+}
+main().catch(e => { console.error(e); process.exit(1); });
