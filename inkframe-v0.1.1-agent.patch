+name: Export GIF
+
+# Headless .inkframe → GIF export
+# Trigger via:
+#   gh workflow run export-gif.yml -f archive=myproject.inkframe -f fps=24
+#
+# Or upload an .inkframe as a workflow artifact input (via the Actions UI).
+#
+# Output: inkframe-export-gif artifact with out.gif
+
+on:
+  workflow_dispatch:
+    inputs:
+      archive:
+        description: 'Path in repo to .inkframe file (e.g. media/demo.inkframe)'
+        required: false
+        default: ''
+      fps:
+        description: 'FPS'
+        required: false
+        default: '12'
+      width:
+        description: 'Output width (blank = native)'
+        required: false
+        default: ''
+
+permissions:
+  contents: read
+
+jobs:
+  export:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Set up Node 20
+        uses: actions/setup-node@v4
+        with:
+          node-version: '20'
+
+      - name: Install export deps
+        run: |
+          cd web
+          npm ci || npm install
+          npm install --no-save puppeteer
+
+      - name: Find archive to export
+        id: find
+        run: |
+          INPUT="${{ inputs.archive }}"
+          if [ -n "$INPUT" ] && [ -f "$INPUT" ]; then
+            echo "archive=$INPUT" >> $GITHUB_OUTPUT
+            exit 0
+          fi
+          # auto-find first .inkframe in repo
+          FOUND=$(find . -name "*.inkframe" -type f | head -1)
+          if [ -n "$FOUND" ]; then
+            echo "archive=$FOUND" >> $GITHUB_OUTPUT
+            echo "Auto-found $FOUND"
+            exit 0
+          fi
+          echo "No .inkframe found in repo. Upload one as an artifact or specify inputs.archive"
+          echo "archive=" >> $GITHUB_OUTPUT
+          exit 1
+
+      - name: Export GIF
+        run: |
+          node tools/inkframe-cli.mjs export-gif \
+            "${{ steps.find.outputs.archive }}" \
+            out.gif \
+            --fps ${{ inputs.fps }} \
+            ${{ inputs.width && format('--width {0}', inputs.width) || '' }}
+
+      - name: Upload GIF
+        uses: actions/upload-artifact@v4
+        with:
+          name: inkframe-export-gif
+          path: out.gif
+          retention-days: 14
