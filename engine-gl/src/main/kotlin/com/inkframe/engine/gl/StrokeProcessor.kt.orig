package com.inkframe.engine.gl

import android.view.MotionEvent
import com.inkframe.core.common.Vec2
import com.inkframe.core.common.catmullRom
import com.inkframe.core.common.lerp
import com.inkframe.core.model.Brush
import kotlin.math.max
import kotlin.math.sqrt

/**
 * A single sampled point of a stylus stroke.
 *
 * @param pos       Canvas-space position.
 * @param pressure  Normalised pressure 0..1.
 * @param timeMs    Event timestamp in milliseconds.
 * @param tiltRad   Stylus tilt from vertical, radians (0 = perpendicular, π/2 = flat).
 *                  Sourced from MotionEvent.AXIS_TILT. Defaults to 0 (no tilt).
 * @param azimuthRad Stylus azimuth (compass bearing of the tilt direction), radians.
 *                  Sourced from MotionEvent.AXIS_ORIENTATION. Defaults to 0.
 */
data class InputSample(
    val pos: Vec2,
    val pressure: Float,
    val timeMs: Long,
    val tiltRad: Float = 0f,
    val azimuthRad: Float = 0f,
)

/**
 * One brush dab ready to be stamped.
 *
 * @param center      Dab centre in canvas pixels.
 * @param size        Dab diameter in canvas pixels (pressure + velocity modulated).
 * @param rotationRad Dab rotation in radians (driven by stylus azimuth for non-round tips).
 * @param flow        Per-dab coverage 0..1 written into the scratch buffer.
 * @param tiltRad     Stylus tilt at this dab (passed to the shader for tip distortion).
 */
data class Dab(
    val center: Vec2,
    val size: Float,
    val rotationRad: Float,
    val flow: Float,
    val tiltRad: Float = 0f,
)

/**
 * Converts a noisy stream of stylus samples into a clean run of evenly spaced dabs.
 *
 * Pipeline per added sample:
 *   1. Exponential smoothing of position (brush.smoothing) to reduce jitter.
 *   2. Catmull-Rom interpolation between the last control points for smooth curves.
 *   3. Arc-length resampling at `spacing × diameter` so coverage is uniform
 *      regardless of stroke speed.
 *   4. Velocity tapering: fast strokes produce thinner dabs (natural ink behaviour).
 *   5. Tilt/azimuth forwarded to each dab so the shader can rotate non-round tips.
 *
 * The processor is stateful per stroke; create one (or call [reset]) per stroke.
 */
class StrokeProcessor(private val brush: Brush) {
    private val raw = ArrayList<InputSample>()
    private var smoothed: Vec2? = null
    private var carry = 0f
    private var lastTimeMs: Long = -1L
    private var lastPos: Vec2? = null

    fun reset() {
        raw.clear()
        smoothed = null
        carry = 0f
        lastTimeMs = -1L
        lastPos = null
    }

    /** Pushes a sample and returns any dabs produced since the previous call. */
    fun add(sample: InputSample): List<Dab> {
        val s = brush.smoothing.coerceIn(0f, 0.95f)
        val prev = smoothed
        val sm = if (prev == null) sample.pos else lerp(prev, sample.pos, 1f - s)
        smoothed = sm

        // Compute instantaneous velocity (canvas px / ms) for tapering.
        val velocity = computeVelocity(sm, sample.timeMs)
        lastPos = sm
        lastTimeMs = sample.timeMs

        raw.add(InputSample(sm, sample.pressure, sample.timeMs, sample.tiltRad, sample.azimuthRad))

        if (raw.size < 4) return emptyList()
        val n = raw.size
        return resampleSegment(raw[n - 4], raw[n - 3], raw[n - 2], raw[n - 1], velocity)
    }

    /** Flushes the final tail so the stroke reaches its last input point. */
    fun finish(): List<Dab> {
        if (raw.size < 2) {
            val only = raw.firstOrNull() ?: return emptyList()
            return listOf(dabAt(only.pos, only.pressure, only.tiltRad, only.azimuthRad, velocity = 0f))
        }
        val n = raw.size
        val a = raw[max(0, n - 2)]
        val b = raw[n - 1]
        return resampleSegment(a, a, b, b, velocity = 0f)
    }

    private fun computeVelocity(pos: Vec2, timeMs: Long): Float {
        val lp = lastPos ?: return 0f
        val dt = (timeMs - lastTimeMs).toFloat().coerceAtLeast(1f)
        val dx = pos.x - lp.x
        val dy = pos.y - lp.y
        return sqrt(dx * dx + dy * dy) / dt  // px/ms
    }

    private fun resampleSegment(
        s0: InputSample,
        s1: InputSample,
        s2: InputSample,
        s3: InputSample,
        velocity: Float,
    ): List<Dab> {
        val dabs = ArrayList<Dab>()
        val approxLen = s1.pos.distanceTo(s2.pos)
        val avgPressure = (s1.pressure + s2.pressure) * 0.5f

        // Velocity tapering: fast strokes thin the dab by up to 40%.
        // Clamp velocity to a sensible max (20 px/ms ≈ very fast stroke).
        val velocityFactor = (1f - (velocity / 20f).coerceIn(0f, 1f) * 0.4f)
        val diameter = brush.diameterForPressure(avgPressure) * velocityFactor * velocityFactor

        val step = max(1f, brush.spacing * diameter * velocityFactor)
        val subdiv = max(1, (approxLen / step).toInt() * 2)

        var t = 0f
        val dt = 1f / subdiv
        var i = 0
        while (i <= subdiv) {
            val p = catmullRom(s0.pos, s1.pos, s2.pos, s3.pos, t)
            val pressure = lerp(s1.pressure, s2.pressure, t)
            val tilt = lerp(s1.tiltRad, s2.tiltRad, t)
            val azimuth = lerp(s1.azimuthRad, s2.azimuthRad, t)
            t += dt; i++
            if (dabs.isEmpty()) {
                dabs.add(dabAt(p, pressure, tilt, azimuth, velocity)); continue
            }
            val last = dabs.last().center
            carry += p.distanceTo(last)
            if (carry >= step) {
                carry = 0f
                dabs.add(dabAt(p, pressure, tilt, azimuth, velocity))
            }
        }
        return dabs
    }

    private fun dabAt(
        p: Vec2,
        pressure: Float,
        tiltRad: Float,
        azimuthRad: Float,
        velocity: Float,
    ): Dab {
        val velocityFactor = (1f - (velocity / 20f).coerceIn(0f, 1f) * 0.4f)
        return Dab(
            center = p,
            size = brush.diameterForPressure(pressure) * velocityFactor,
            // Use azimuth as the dab rotation so non-round tips align with the pen direction.
            rotationRad = azimuthRad,
            flow = brush.flowForPressure(pressure),
            tiltRad = tiltRad,
        )
    }
}
