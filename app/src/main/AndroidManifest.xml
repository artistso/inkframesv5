<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <supports-screens
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:requiresSmallestWidthDp="320" />

    <application
        android:name=".InkFrameStudioApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_glass_horizon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_glass_horizon"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.InkFrame">

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|uiMode|density|smallestScreenSize"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:screenOrientation="userLandscape"
            android:theme="@style/Theme.InkFrame" />

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:hardwareAccelerated="true"
            android:noHistory="true"
            android:screenOrientation="userLandscape"
            android:theme="@style/Theme.InkFrame.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
