<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed only if the WebView ever tries to fetch a remote URL; the bundled
         app is fully offline, but include it so future features (e.g. cloud
         export) don't require a manifest change. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Save exported PNGs to shared storage on pre-Q devices. On Android 10+
         MediaStore doesn't need this permission at all. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Phones + tablets both welcome; the app is landscape-first. -->
    <supports-screens
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:requiresSmallestWidthDp="320" />

    <application
        android:name=".InkFrameApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_glass_horizon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_glass_horizon"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.InkFrame">

        <!-- Production Kotlin canvas beta. It is intentionally a second launcher entry while
             project-format and feature parity are established; the WebView studio remains intact. -->
        <activity
            android:name=".nativeink.NativeArtistActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|uiMode|density|smallestScreenSize"
            android:exported="true"
            android:hardwareAccelerated="true"
            android:label="InkFrame Native Canvas Beta"
            android:screenOrientation="userLandscape"
            android:theme="@style/Theme.InkFrame">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|uiMode|density|smallestScreenSize"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:screenOrientation="userLandscape"
            android:theme="@style/Theme.InkFrame" />

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:hardwareAccelerated="true"
            android:noHistory="true"
            android:screenOrientation="userLandscape"
            android:theme="@style/Theme.InkFrame.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
